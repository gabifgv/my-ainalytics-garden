---
import { getCollection } from 'astro:content';
const allPosts = await getCollection('garden');

const sortedPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const flowerMeta: Record<string, { color: string; label: string }> = {
  dandelion: { color: "#d97a8a", label: "=> Dandelion_Type" },
  lavender:  { color: "#827397", label: "{ } Lavender_Type" },
  tulip:     { color: "#c48b52", label: "[ ] Tulip_Type" },
  rose:      { color: "#c0435a", label: "| | Rose_Type" },
  sunflower: { color: "#f4a261", label: "( ) Sunflower_Type" },
  wheat:     { color: "#d4a04a", label: "// Wheat_Type" },
  bamboo:    { color: "#3a7d44", label: "[] Bamboo_Type" },
  coral:     { color: "#e07a5f", label: "~~ Coral_Type" },
  ginkgo:    { color: "#b8860b", label: "<> Ginkgo_Type" },
  cosmos:    { color: "#c87fb8", label: "** Cosmos_Type" },
  thistle:   { color: "#6b5e9e", label: ":: Thistle_Type" },
  lotus:     { color: "#c05070", label: "@@ Lotus_Type" },
  cactus:    { color: "#4d7c3f", label: "|_| Cactus_Type" },
};
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>my AInalytics garden</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500&family=Space+Mono&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-color: #fcfaf6;
            --text-main: #2d2d2d;
            --text-muted: #857f76;
            --border-color: #e5e0d8;
            --stem-color: #7a8c71;
            --main-font: 'Gotham', 'Space Grotesk', sans-serif;
            --code-font: 'Gotham Code', 'Space Mono', monospace;
        }

        * { box-sizing: border-box; }

        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            font-family: var(--main-font);
            margin: 0;
            padding: 50px 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
            -webkit-font-smoothing: antialiased;
        }

        /* --- Overlay --- */
        .overlay {
            position: fixed;
            top: 0; left: 0;
            width: 100vw; height: 100vh;
            background: rgba(252, 250, 246, 0.7);
            backdrop-filter: blur(3px);
            z-index: 998;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.4s ease;
        }
        .overlay.active { opacity: 1; pointer-events: auto; }

        /* --- Sidebar --- */
        .sidebar {
            position: fixed;
            top: 0; left: -400px;
            width: 350px; height: 100vh;
            background: #ffffff;
            box-shadow: 4px 0 20px rgba(0,0,0,0.04);
            z-index: 999;
            padding: 50px 40px;
            transition: left 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
            display: flex;
            flex-direction: column;
        }
        .sidebar.active { left: 0; }

        .close-btn {
            background: none; border: none;
            font-size: 2rem; font-weight: 300;
            color: var(--text-muted);
            cursor: pointer;
            align-self: flex-end;
            margin-bottom: 20px;
            line-height: 1;
        }

        .sidebar-title { font-size: 1.5rem; font-weight: 500; margin: 0 0 5px 0; }
        .sidebar-tag {
            font-family: var(--code-font);
            font-size: 0.75rem;
            color: var(--stem-color);
            margin-bottom: 30px;
            display: block;
        }
        .sidebar-text {
            font-size: 0.95rem;
            line-height: 1.8;
            color: var(--text-muted);
            border-left: 2px solid var(--border-color);
            padding-left: 15px;
        }

        /* --- Header --- */
        header {
            width: 100%;
            max-width: 1200px;
            text-align: center;
            margin-bottom: 60px;
            position: relative;
        }

        .menu-btn {
            position: absolute;
            top: 10px; left: 0;
            background: none; border: none;
            cursor: pointer;
            padding: 10px;
            color: var(--stem-color);
            transition: opacity 0.2s;
        }
        .menu-btn:hover { opacity: 0.7; }

        .site-title {
            font-size: 3.5rem;
            font-weight: 300;
            color: #4a5c4e;
            margin: 0 0 10px 0;
            letter-spacing: -1px;
        }

        .subtitle-code {
            font-family: var(--code-font);
            font-size: 0.85rem;
            color: var(--text-muted);
            letter-spacing: 1px;
        }

        /* --- Grid --- */
        .garden-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 40px;
            width: 100%;
            max-width: 1200px;
        }

        .botanical-card {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-decoration: none;
            color: inherit;
            transition: transform 0.3s ease;
        }
        .botanical-card:hover { transform: translateY(-5px); }

        .card-meta {
            width: 100%;
            border-top: 1px solid var(--border-color);
            padding-top: 15px;
            margin-top: 10px;
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }

        .post-title { font-size: 1.4rem; font-weight: 500; margin: 0 0 5px 0; }
        .post-category {
            font-family: var(--code-font);
            font-size: 0.7rem;
            color: var(--stem-color);
            text-transform: uppercase;
        }
        .post-id {
            font-family: var(--code-font);
            font-size: 0.8rem;
            color: var(--text-muted);
            white-space: nowrap;
        }

        svg { max-height: 350px; }
    </style>
</head>
<body>

    <div class="overlay" id="menuOverlay"></div>

    <nav class="sidebar" id="aboutSidebar">
        <button class="close-btn" id="closeBtn">&times;</button>
        <h2 class="sidebar-title">README.md</h2>
        <span class="sidebar-tag">> whoami</span>
        <p class="sidebar-text">
            Leading Data and AI ecosystems to drive real business impact. Between designing scalable architectures, MLOps, and GenAI strategies, this space serves as a living archive of my learnings. When I'm not optimizing pipelines, I split my time cultivating my reading habit and training my pace for upcoming marathons.
        </p>
    </nav>

    <header>
        <button class="menu-btn" id="menuBtn" aria-label="Open menu">
            <svg width="28" height="20" viewBox="0 0 28 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect width="28" height="2" fill="currentColor"/>
                <rect y="9" width="20" height="2" fill="currentColor"/>
                <rect y="18" width="28" height="2" fill="currentColor"/>
            </svg>
        </button>
        <h1 class="site-title">my AInalytics garden</h1>
        <div class="subtitle-code">const author: Manager&lt;AI, Analytics&gt; = "Gabriella Pinheiro"; // insights catalog</div>
    </header>

    <main class="garden-grid">
        {sortedPosts.map(post => {
            const type = post.data.flower_type || (post.data.category === 'GenAI' ? 'dandelion' : post.data.category === 'MLOps' ? 'lavender' : 'tulip');
            const meta = flowerMeta[type] ?? flowerMeta.tulip;
            const key = post.data.keyword || "Data";
            const rep = `${key} ${key} ${key}`;
            const col = meta.color;

            return (
                <a href={`/garden/${post.slug}`} class="botanical-card">
                    <svg viewBox="0 0 300 400" width="100%" height="auto">
                        {/* Base: folha + caule */}
                        <path d="M 110 380 Q 150 410 190 380 L 180 300 Q 150 310 120 300 Z" fill="#f0ebd8" opacity="0.6"/>

                        {/* Dandelion — raios radiais com texto repetido */}
                        {type === "dandelion" && <>
                            <path d="M 150 305 Q 140 200 150 140" stroke="var(--stem-color)" stroke-width="3" fill="none"/>
                            <g transform="translate(150, 140)" font-family="var(--main-font)" font-size="11" font-weight="bold" fill={meta.color}>
                                {[-90,-60,-30,0,30,60,90,120,150,180,210,240,270,300,330].map(angle => (
                                    <text transform={`rotate(${angle}) translate(10, 4)`}>{rep}</text>
                                ))}
                            </g>
                        </>}

                        {/* Lavender — alternando lados ao longo do caule */}
                        {type === "lavender" && <>
                            <path d="M 150 305 L 150 70" stroke="var(--stem-color)" stroke-width="3" fill="none"/>
                            <g font-family="var(--main-font)" font-size="12" font-weight="bold" fill={meta.color}>
                                {[260,240,220,200,180,160,140,120,100,80].map((y, i) => (
                                    <text transform={`translate(${i % 2 === 0 ? 155 : 145}, ${y}) rotate(${i % 2 === 0 ? -15 : 195})`}>{key}</text>
                                ))}
                                <text transform="translate(150, 60) rotate(-90)">{key}</text>
                            </g>
                        </>}

                        {/* Tulip — pétalas abertas em leque */}
                        {type === "tulip" && <>
                            <path d="M 150 305 Q 160 220 150 180" stroke="var(--stem-color)" stroke-width="3" fill="none"/>
                            <g font-family="var(--main-font)" font-size="11" font-weight="bold" fill={meta.color}>
                                {[-135,-120,-105,-90,-75,-60,-45].map((angle, i) => (
                                    <text transform={`translate(${150 + (i < 3 ? -(3-i)*15 : i > 3 ? (i-3)*15 : 0)}, ${180 - Math.abs(i-3)*15}) rotate(${angle})`} text-anchor="start">{key}</text>
                                ))}
                            </g>
                        </>}

                        {/* Rose — espiral de pétalas */}
                        {type === "rose" && <>
                            <path d="M 150 305 Q 150 240 150 190" stroke="var(--stem-color)" stroke-width="3" fill="none"/>
                            <g transform="translate(150, 175)" font-family="var(--main-font)" font-size="11" font-weight="bold" fill={meta.color}>
                                {[0,30,60,90,120,150,180,210,240,270,300,330].map((angle, i) => (
                                    <text transform={`rotate(${angle}) translate(${8 + (i % 3) * 4}, ${(i % 3) * 3})`}>{key}</text>
                                ))}
                            </g>
                        </>}

                        {/* Sunflower — raios densos ao redor do centro */}
                        {type === "sunflower" && <>
                            <path d="M 150 305 Q 150 230 150 195" stroke="var(--stem-color)" stroke-width="3" fill="none"/>
                            <g transform="translate(150, 175)" font-family="var(--main-font)" font-size="10" font-weight="bold" fill={meta.color}>
                                {[...Array(18)].map((_, i) => (
                                    <text transform={`rotate(${i * 20}) translate(30, 3)`}>{key}</text>
                                ))}
                            </g>
                        </>}

                        {/* Wheat — espiga com grãos alternados */}
                        {type === "wheat" && <>
                            <path d="M 150 305 L 150 75" stroke="var(--stem-color)" stroke-width="3" fill="none"/>
                            <g font-family="var(--main-font)" font-size="11" font-weight="bold" fill={col}>
                                {[...Array(5)].map((_, i) => (<>
                                    <text transform={`translate(158,${280 - i*26}) rotate(-38)`}>{key}</text>
                                    <text transform={`translate(132,${267 - i*26}) rotate(218)`}>{key}</text>
                                </>))}
                                <text transform="translate(150,80) rotate(-90)" text-anchor="middle">{key}</text>
                            </g>
                        </>}

                        {/* Bamboo — segmentos com folhas */}
                        {type === "bamboo" && <>
                            <g font-family="var(--main-font)" font-size="10" font-weight="bold" fill={col}>
                                {[...Array(5)].map((_, i) => (<>
                                    <rect x="136" y={258 - i*52} width="28" height="48" fill="none" stroke="var(--stem-color)" stroke-width="2.5" rx="3"/>
                                    <text transform={`translate(${i % 2 === 0 ? 167 : 108},${282 - i*52}) rotate(${i % 2 === 0 ? -35 : 210})`}>{key}</text>
                                </>))}
                            </g>
                        </>}

                        {/* Coral — ramificações com keyword nas pontas */}
                        {type === "coral" && <>
                            <path d="M 150 305 Q 150 245 150 205" stroke="var(--stem-color)" stroke-width="3" fill="none"/>
                            <path d="M 150 205 Q 112 175 80 155" stroke="var(--stem-color)" stroke-width="2" fill="none"/>
                            <path d="M 150 205 Q 188 175 220 155" stroke="var(--stem-color)" stroke-width="2" fill="none"/>
                            <path d="M 150 205 Q 150 170 150 148" stroke="var(--stem-color)" stroke-width="2" fill="none"/>
                            <path d="M 80 155 Q 58 128 48 108" stroke="var(--stem-color)" stroke-width="1.5" fill="none"/>
                            <path d="M 80 155 Q 92 128 98 108" stroke="var(--stem-color)" stroke-width="1.5" fill="none"/>
                            <path d="M 220 155 Q 208 128 202 108" stroke="var(--stem-color)" stroke-width="1.5" fill="none"/>
                            <path d="M 220 155 Q 232 128 242 108" stroke="var(--stem-color)" stroke-width="1.5" fill="none"/>
                            <path d="M 150 148 Q 140 122 136 102" stroke="var(--stem-color)" stroke-width="1.5" fill="none"/>
                            <path d="M 150 148 Q 160 122 164 102" stroke="var(--stem-color)" stroke-width="1.5" fill="none"/>
                            <g font-family="var(--main-font)" font-size="9" font-weight="bold" fill={col}>
                                <text x="20" y="108">{key}</text>
                                <text x="82" y="108">{key}</text>
                                <text x="122" y="100">{key}</text>
                                <text x="158" y="100">{key}</text>
                                <text x="198" y="108">{key}</text>
                                <text x="238" y="108">{key}</text>
                            </g>
                        </>}

                        {/* Ginkgo — leque semicircular */}
                        {type === "ginkgo" && <>
                            <path d="M 150 305 L 150 215" stroke="var(--stem-color)" stroke-width="3" fill="none"/>
                            <path d="M 62 202 Q 96 118 150 210 Q 204 118 238 202 Q 200 186 150 210 Q 100 186 62 202 Z" fill="#f2cc8f" opacity="0.2"/>
                            <g font-family="var(--main-font)" font-size="9" font-weight="bold" fill={col}>
                                {[-80,-60,-40,-20,0,20,40,60,80].map(angle => {
                                    const tx = (150 + 84 * Math.cos((angle-90)*Math.PI/180)).toFixed(1);
                                    const ty = (198 + 84 * Math.sin((angle-90)*Math.PI/180)).toFixed(1);
                                    return <text transform={`translate(${tx},${ty}) rotate(${angle})`} text-anchor="middle">{key}</text>
                                })}
                            </g>
                        </>}

                        {/* Cosmos — pétalas longas ao redor do centro */}
                        {type === "cosmos" && <>
                            <path d="M 150 305 Q 150 235 150 192" stroke="var(--stem-color)" stroke-width="3" fill="none"/>
                            <g transform="translate(150,192)" font-family="var(--main-font)" font-size="9" font-weight="bold" fill={col}>
                                {[...Array(12)].map((_, i) => (
                                    <text transform={`rotate(${i*30}) translate(26,3)`}>{key}</text>
                                ))}
                            </g>
                            <circle cx="150" cy="192" r="8" fill={col} opacity="0.5"/>
                        </>}

                        {/* Thistle — bola espinhosa */}
                        {type === "thistle" && <>
                            <path d="M 150 305 Q 150 218 150 182" stroke="var(--stem-color)" stroke-width="3" fill="none"/>
                            <circle cx="150" cy="148" r="48" fill={col} opacity="0.07"/>
                            <g transform="translate(150,148)" font-family="var(--main-font)" font-size="7" font-weight="bold" fill={col}>
                                {[...Array(20)].map((_, i) => (
                                    <text transform={`rotate(${i*18}) translate(${i%2===0?50:38},3)`}>{key}</text>
                                ))}
                            </g>
                            <circle cx="150" cy="148" r="12" fill={col} opacity="0.3"/>
                        </>}

                        {/* Lotus — camadas concêntricas */}
                        {type === "lotus" && <>
                            <path d="M 150 305 Q 150 238 150 212" stroke="var(--stem-color)" stroke-width="3" fill="none"/>
                            <g transform="translate(150,200)" font-family="var(--main-font)" font-weight="bold" fill={col}>
                                {[...Array(8)].map((_, i) => <text font-size="8" transform={`rotate(${i*45-90}) translate(58,3)`}>{key}</text>)}
                                {[...Array(6)].map((_, i) => <text font-size="8" transform={`rotate(${i*60-60}) translate(34,3)`} fill="#d97a8a">{key}</text>)}
                                {[...Array(4)].map((_, i) => <text font-size="9" transform={`rotate(${i*90-45}) translate(16,3)`} fill="#c05070">{key}</text>)}
                            </g>
                            <circle cx="150" cy="200" r="7" fill="#c05070" opacity="0.5"/>
                        </>}

                        {/* Cactus — corpo com braços */}
                        {type === "cactus" && <>
                            <path d="M 130 295 Q 112 292 112 272 L 112 165 Q 112 148 130 148 L 170 148 Q 188 148 188 165 L 188 272 Q 188 292 170 295 Z" fill="#deecd8" opacity="0.35" stroke="var(--stem-color)" stroke-width="2.5"/>
                            <path d="M 112 205 L 78 205 Q 62 205 62 190 L 62 148 Q 62 133 78 133 L 112 133" fill="#deecd8" opacity="0.35" stroke="var(--stem-color)" stroke-width="2.5"/>
                            <path d="M 188 190 L 222 190 Q 238 190 238 175 L 238 133 Q 238 118 222 118 L 188 118" fill="#deecd8" opacity="0.35" stroke="var(--stem-color)" stroke-width="2.5"/>
                            <g font-family="var(--main-font)" font-size="8" font-weight="bold" fill={col} text-anchor="middle">
                                <text x="150" y="278">{key}</text>
                                <text x="150" y="260">{key}</text>
                                <text x="150" y="242">{key}</text>
                                <text x="150" y="224">{key}</text>
                                <text x="150" y="206">{key}</text>
                                <text x="150" y="188">{key}</text>
                                <text x="150" y="170">{key}</text>
                                <text x="86" y="196" font-size="7">{key}</text>
                                <text x="86" y="180" font-size="7">{key}</text>
                                <text x="86" y="164" font-size="7">{key}</text>
                                <text x="86" y="148" font-size="7">{key}</text>
                                <text x="214" y="181" font-size="7">{key}</text>
                                <text x="214" y="165" font-size="7">{key}</text>
                                <text x="214" y="149" font-size="7">{key}</text>
                                <text x="214" y="133" font-size="7">{key}</text>
                            </g>
                        </>}
                    </svg>

                    <div class="card-meta">
                        <div>
                            <h2 class="post-title">{post.data.title}</h2>
                            <span class="post-category">{meta.label}</span>
                        </div>
                        {post.data.id && <div class="post-id">{post.data.id}</div>}
                    </div>
                </a>
            );
        })}
    </main>

    <script>
        const menuBtn = document.getElementById('menuBtn');
        const closeBtn = document.getElementById('closeBtn');
        const sidebar = document.getElementById('aboutSidebar');
        const overlay = document.getElementById('menuOverlay');

        function openMenu() {
            sidebar?.classList.add('active');
            overlay?.classList.add('active');
        }

        function closeMenu() {
            sidebar?.classList.remove('active');
            overlay?.classList.remove('active');
        }

        menuBtn?.addEventListener('click', openMenu);
        closeBtn?.addEventListener('click', closeMenu);
        overlay?.addEventListener('click', closeMenu);
    </script>
</body>
</html>
