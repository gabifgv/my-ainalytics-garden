---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

// 1. Importação das Plantas (Adicione as novas aqui conforme criar os componentes)
import DandelionPlant from '../../components/DandelionPlant.astro';
import LavenderPlant from '../../components/LavenderPlant.astro';
import TulipPlant from '../../components/TulipPlant.astro';
import RosePlant from '../../components/RosePlant.astro';
import SunflowerPlant from '../../components/SunflowerPlant.astro';
import WheatPlant from '../../components/WheatPlant.astro';
import BambooPlant from '../../components/BambooPlant.astro';
import CoralPlant from '../../components/CoralPlant.astro';
import GinkgoPlant from '../../components/GinkgoPlant.astro';
import CosmosPlant from '../../components/CosmosPlant.astro';
import ThistlePlant from '../../components/ThistlePlant.astro';
import LotusPlant from '../../components/LotusPlant.astro';
import CactusPlant from '../../components/CactusPlant.astro';

export async function getStaticPaths() {
  const posts = await getCollection('garden');
  return posts.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// 2. Extraímos o flower_type do metadado do post
const { title, date, category, keyword, id, author, status, flower_type } = entry.data;

// 3. Lógica de Decisão (Prioridade: flower_type > category)
const activeFlower = flower_type || 
                     (category === 'GenAI' ? 'dandelion' : 
                      category === 'MLOps' ? 'lavender' : 
                      'tulip');

const categoryLabel: Record<string, string> = {
  'GenAI': '=> Dandelion_Type',
  'MLOps': '{ } Lavender_Type',
  'Data Architecture': '[ ] Tulip_Type',
  'Management': '| | Rose_Type', // Exemplo
};

const formattedDate = date.toLocaleDateString('en-US', {
  month: 'long', day: 'numeric', year: 'numeric',
});
---

<BaseLayout title={`${title} · my AInalytics garden`} description={`${title} by Gabriella Pinheiro`}>
  <article class="post-page">
    <a href="/" class="back-link">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M 10 7 L 4 7 M 4 7 L 7 4 M 4 7 L 7 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      cd ../garden
    </a>

    <header class="post-header">
      <div class="post-header-plant">
        {/* 4. O NOVO SELETOR DINÂMICO */}
        {activeFlower === 'dandelion' && <DandelionPlant keyword={keyword} />}
        {activeFlower === 'lavender' && <LavenderPlant keyword={keyword} />}
        {activeFlower === 'tulip' && <TulipPlant keyword={keyword} />}
        {activeFlower === 'rose' && <RosePlant keyword={keyword} />}
        {activeFlower === 'sunflower' && <SunflowerPlant keyword={keyword} />}
        {activeFlower === 'wheat' && <WheatPlant keyword={keyword} />}
        {activeFlower === 'bamboo' && <BambooPlant keyword={keyword} />}
        {activeFlower === 'coral' && <CoralPlant keyword={keyword} />}
        {activeFlower === 'ginkgo' && <GinkgoPlant keyword={keyword} />}
        {activeFlower === 'cosmos' && <CosmosPlant keyword={keyword} />}
        {activeFlower === 'thistle' && <ThistlePlant keyword={keyword} />}
        {activeFlower === 'lotus' && <LotusPlant keyword={keyword} />}
        {activeFlower === 'cactus' && <CactusPlant keyword={keyword} />}
      </div>

      <div class="post-header-meta">
        <span class="post-header-category">{categoryLabel[category] ?? category}</span>
        <h1 class="post-header-title">{title}</h1>
        <div class="post-header-date">
          {formattedDate}{author && ` · ${author}`}{id && ` · #${id}`}
        </div>
      </div>
    </header>

    <div class="post-content">
      <Content />
    </div>
  </article>
</BaseLayout>