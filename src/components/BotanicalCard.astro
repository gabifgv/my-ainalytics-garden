---
import type { CollectionEntry } from 'astro:content';

// 1. Importação de TODAS as plantas
import DandelionPlant from './DandelionPlant.astro';
import LavenderPlant from './LavenderPlant.astro';
import TulipPlant from './TulipPlant.astro';
import RosePlant from './RosePlant.astro';
import SunflowerPlant from './SunflowerPlant.astro';
import FernPlant from './FernPlant.astro';
import BambooPlant from './BambooPlant.astro';
import CactusPlant from './CactusPlant.astro';
import CoralPlant from './CoralPlant.astro';
import CosmosPlant from './CosmosPlant.astro';
import GinkgoPlant from './GinkgoPlant.astro';
import LotusPlant from './LotusPlant.astro';
import ThistlePlant from './ThistlePlant.astro';
import VinePlant from './VinePlant.astro';
import WheatPlant from './WheatPlant.astro';

interface Props {
  post: CollectionEntry<'garden'>;
}

const { post } = Astro.props;
const { title, category, keyword, id, flower_type } = post.data;

/**
 * 2. LÓGICA DE PRIORIDADE:
 * Se você definiu flower_type no .md, ele ganha.
 * Se não, ele usa o padrão da categoria.
 */
const activeFlower = flower_type ||
                      (category === 'GenAI' ? 'dandelion' :
                       category === 'MLOps' ? 'lavender' :
                       'tulip');

const categoryLabel: Record<string, string> = {
  'GenAI': '=> Dandelion_Type',
  'MLOps': '{ } Lavender_Type',
  'Data Architecture': '[ ] Tulip_Type',
};

// Label para todas as flores manuais
const flowerLabels: Record<string, string> = {
  'fern':     '>> Fern_Type',
  'rose':     '| | Rose_Type',
  'sunflower':'( ) Sunflower_Type',
  'bamboo':   '|| Bamboo_Type',
  'cactus':   '/\\ Cactus_Type',
  'coral':    '~~ Coral_Type',
  'cosmos':   '** Cosmos_Type',
  'ginkgo':   '<> Ginkgo_Type',
  'lotus':    '() Lotus_Type',
  'thistle':  ':; Thistle_Type',
  'vine':     '~> Vine_Type',
  'wheat':    '## Wheat_Type',
};
---

<a href={`/garden/${post.slug}`} class="botanical-card">
  <div class="flower-container" style="display: flex; justify-content: center; width: 100%;">
    {/* 3. SELETOR COMPLETO — todas as plantas mapeadas */}
    {activeFlower === 'dandelion'  && <DandelionPlant  keyword={keyword} />}
    {activeFlower === 'lavender'   && <LavenderPlant   keyword={keyword} />}
    {activeFlower === 'tulip'      && <TulipPlant      keyword={keyword} />}
    {activeFlower === 'rose'       && <RosePlant       keyword={keyword} />}
    {activeFlower === 'sunflower'  && <SunflowerPlant  keyword={keyword} />}
    {activeFlower === 'fern'       && <FernPlant       keyword={keyword} />}
    {activeFlower === 'bamboo'     && <BambooPlant     keyword={keyword} />}
    {activeFlower === 'cactus'     && <CactusPlant     keyword={keyword} />}
    {activeFlower === 'coral'      && <CoralPlant      keyword={keyword} />}
    {activeFlower === 'cosmos'     && <CosmosPlant     keyword={keyword} />}
    {activeFlower === 'ginkgo'     && <GinkgoPlant     keyword={keyword} />}
    {activeFlower === 'lotus'      && <LotusPlant      keyword={keyword} />}
    {activeFlower === 'thistle'    && <ThistlePlant    keyword={keyword} />}
    {activeFlower === 'vine'       && <VinePlant       keyword={keyword} />}
    {activeFlower === 'wheat'      && <WheatPlant      keyword={keyword} />}
  </div>

  <div class="card-meta">
    <div>
      <h2 class="post-title">{title}</h2>
      <span class="post-category">
        {flower_type ? (flowerLabels[flower_type] || flower_type) : (categoryLabel[category] ?? category)}
      </span>
    </div>
    {id && <div class="post-id">{id}</div>}
  </div>
</a>