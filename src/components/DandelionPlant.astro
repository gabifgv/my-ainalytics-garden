---
interface Props {
  keyword: string;
}
const { keyword } = Astro.props;
const label = `${keyword} ${keyword} ${keyword}`;
const angles = Array.from({ length: 15 }, (_, i) => -90 + i * 30);
---
<svg viewBox="0 0 300 400" width="100%" height="auto" aria-hidden="true">
  <!-- Pot -->
  <path d="M 110 380 Q 150 410 190 380 L 180 300 Q 150 310 120 300 Z" fill="#f0ebd8" opacity="0.6"/>
  <!-- Stem -->
  <path d="M 150 305 Q 140 200 150 140" stroke="var(--stem-color)" stroke-width="3" fill="none"/>
  <!-- Dandelion petals — each petal is the keyword repeated -->
  <g transform="translate(150, 140)" font-family="'Gotham', 'Space Mono', monospace" font-size="11" font-weight="bold" fill="#d97a8a">
    {angles.map((angle) => (
      <text transform={`rotate(${angle}) translate(10, 4)`}>{label}</text>
    ))}
  </g>
</svg>
