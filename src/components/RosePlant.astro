---
const { keyword } = Astro.props;
---
<svg viewBox="0 0 300 400" width="100%" height="auto">
  <path d="M 150 305 Q 150 250 150 200" stroke="var(--stem-color)" stroke-width="3" fill="none"/>
  <g transform="translate(150, 180)" font-family="monospace" font-size="10" font-weight="bold" fill="#e63946">
    {[...Array(6)].map((_, i) => (
      <text transform={`rotate(${i * 60}) translate(${10 + i*2}, ${i*2})`}>{keyword}</text>
    ))}
  </g>
</svg>