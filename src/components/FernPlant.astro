---
const { keyword } = Astro.props;
---
<svg viewBox="0 0 300 400" width="100%" height="auto">
  <path d="M 150 305 Q 150 250 150 200" stroke="var(--stem-color)" stroke-width="3" fill="none"/>
  <g transform="translate(150, 180)" font-family="monospace" font-size="10" font-weight="bold" fill="#3a5335">
    {[...Array(10)].map((_, i) => (
      <text transform={`translate(${i % 2 === 0 ? 15 : -55}, ${-i * 18}) rotate(${i % 2 === 0 ? 10 : -10})`}>{keyword}</text>
    ))}
  </g>
</svg>