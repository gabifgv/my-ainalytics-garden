---
interface Props { keyword: string; }
const { keyword } = Astro.props;
const strip = Array(14).fill(keyword).join(' ');
const uid = Math.random().toString(36).slice(2, 8);
---
<svg viewBox="0 0 300 400" width="100%" height="auto" aria-hidden="true">
  <defs>
    <!-- Clip regions for each cactus section -->
    <clipPath id={`mb-${uid}`}><rect x="128" y="92" width="44" height="198"/></clipPath>
    <clipPath id={`lh-${uid}`}><rect x="62"  y="182" width="66" height="24"/></clipPath>
    <clipPath id={`lv-${uid}`}><rect x="62"  y="112" width="28" height="70"/></clipPath>
    <clipPath id={`rh-${uid}`}><rect x="172" y="162" width="66" height="24"/></clipPath>
    <clipPath id={`rv-${uid}`}><rect x="210" y="94"  width="28" height="68"/></clipPath>
  </defs>

  <!-- Subtle fills to hint at cactus silhouette -->
  <rect x="128" y="92"  width="44" height="198" rx="12" fill="#d6e8cc" opacity="0.28"/>
  <rect x="62"  y="182" width="66" height="24"  rx="6"  fill="#d6e8cc" opacity="0.28"/>
  <rect x="62"  y="112" width="28" height="70"  rx="6"  fill="#d6e8cc" opacity="0.28"/>
  <rect x="172" y="162" width="66" height="24"  rx="6"  fill="#d6e8cc" opacity="0.28"/>
  <rect x="210" y="94"  width="28" height="68"  rx="6"  fill="#d6e8cc" opacity="0.28"/>

  <g font-family="'Gotham','Space Mono',monospace" font-size="10" font-weight="bold" fill="#4d7c3f">

    <!-- Main body: 3 vertical text columns going upward -->
    <g clip-path={`url(#mb-${uid})`}>
      <text transform="translate(138, 287) rotate(-90)">{strip}</text>
      <text transform="translate(150, 287) rotate(-90)">{strip}</text>
      <text transform="translate(162, 287) rotate(-90)">{strip}</text>
    </g>

    <!-- Left arm — horizontal part: text flows leftward -->
    <g clip-path={`url(#lh-${uid})`}>
      <text transform="translate(128, 191) rotate(180)">{strip}</text>
      <text transform="translate(128, 203) rotate(180)">{strip}</text>
    </g>

    <!-- Left arm — vertical part: text flows upward -->
    <g clip-path={`url(#lv-${uid})`}>
      <text transform="translate(72, 182) rotate(-90)">{strip}</text>
      <text transform="translate(86, 182) rotate(-90)">{strip}</text>
    </g>

    <!-- Right arm — horizontal part: text flows rightward -->
    <g clip-path={`url(#rh-${uid})`}>
      <text transform="translate(172, 171) rotate(0)">{strip}</text>
      <text transform="translate(172, 183) rotate(0)">{strip}</text>
    </g>

    <!-- Right arm — vertical part: text flows upward -->
    <g clip-path={`url(#rv-${uid})`}>
      <text transform="translate(220, 162) rotate(-90)">{strip}</text>
      <text transform="translate(234, 162) rotate(-90)">{strip}</text>
    </g>

  </g>

  <!-- Junction dots at arm bends -->
  <circle cx="86"  cy="182" r="5" fill="#4d7c3f" opacity="0.5"/>
  <circle cx="214" cy="162" r="5" fill="#4d7c3f" opacity="0.5"/>
</svg>
