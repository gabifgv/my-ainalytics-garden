---
const { keyword } = Astro.props;
---
<svg viewBox="0 0 300 400" width="100%" height="auto">
  <path d="M 150 305 L 150 215" stroke="var(--stem-color)" stroke-width="3" fill="none"/>
  <path d="M 62 202 Q 96 118 150 210 Q 204 118 238 202 Q 200 186 150 210 Q 100 186 62 202 Z" fill="#f2cc8f" opacity="0.22"/>
  <text transform="translate(150,198) rotate(-80) translate(84,3)" text-anchor="middle" font-family="monospace" font-size="9" font-weight="bold" fill="#b8860b">{keyword}</text>
  <text transform="translate(150,198) rotate(-60) translate(84,3)" text-anchor="middle" font-family="monospace" font-size="9" font-weight="bold" fill="#b8860b">{keyword}</text>
  <text transform="translate(150,198) rotate(-40) translate(84,3)" text-anchor="middle" font-family="monospace" font-size="9" font-weight="bold" fill="#b8860b">{keyword}</text>
  <text transform="translate(150,198) rotate(-20) translate(84,3)" text-anchor="middle" font-family="monospace" font-size="9" font-weight="bold" fill="#b8860b">{keyword}</text>
  <text transform="translate(150,198) rotate(0) translate(84,3)" text-anchor="middle" font-family="monospace" font-size="9" font-weight="bold" fill="#b8860b">{keyword}</text>
  <text transform="translate(150,198) rotate(20) translate(84,3)" text-anchor="middle" font-family="monospace" font-size="9" font-weight="bold" fill="#b8860b">{keyword}</text>
  <text transform="translate(150,198) rotate(40) translate(84,3)" text-anchor="middle" font-family="monospace" font-size="9" font-weight="bold" fill="#b8860b">{keyword}</text>
  <text transform="translate(150,198) rotate(60) translate(84,3)" text-anchor="middle" font-family="monospace" font-size="9" font-weight="bold" fill="#b8860b">{keyword}</text>
  <text transform="translate(150,198) rotate(80) translate(84,3)" text-anchor="middle" font-family="monospace" font-size="9" font-weight="bold" fill="#b8860b">{keyword}</text>
</svg>
