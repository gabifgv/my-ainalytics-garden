---
const { keyword } = Astro.props;
---
<svg viewBox="0 0 300 400" width="100%" height="auto">
  <path d="M 150 305 Q 150 235 150 192" stroke="var(--stem-color)" stroke-width="3" fill="none"/>
  <text transform="translate(150,192) rotate(0) translate(26,3)" font-family="monospace" font-size="9" font-weight="bold" fill="#c87fb8">{keyword}</text>
  <text transform="translate(150,192) rotate(30) translate(26,3)" font-family="monospace" font-size="9" font-weight="bold" fill="#c87fb8">{keyword}</text>
  <text transform="translate(150,192) rotate(60) translate(26,3)" font-family="monospace" font-size="9" font-weight="bold" fill="#c87fb8">{keyword}</text>
  <text transform="translate(150,192) rotate(90) translate(26,3)" font-family="monospace" font-size="9" font-weight="bold" fill="#c87fb8">{keyword}</text>
  <text transform="translate(150,192) rotate(120) translate(26,3)" font-family="monospace" font-size="9" font-weight="bold" fill="#c87fb8">{keyword}</text>
  <text transform="translate(150,192) rotate(150) translate(26,3)" font-family="monospace" font-size="9" font-weight="bold" fill="#c87fb8">{keyword}</text>
  <text transform="translate(150,192) rotate(180) translate(26,3)" font-family="monospace" font-size="9" font-weight="bold" fill="#c87fb8">{keyword}</text>
  <text transform="translate(150,192) rotate(210) translate(26,3)" font-family="monospace" font-size="9" font-weight="bold" fill="#c87fb8">{keyword}</text>
  <text transform="translate(150,192) rotate(240) translate(26,3)" font-family="monospace" font-size="9" font-weight="bold" fill="#c87fb8">{keyword}</text>
  <text transform="translate(150,192) rotate(270) translate(26,3)" font-family="monospace" font-size="9" font-weight="bold" fill="#c87fb8">{keyword}</text>
  <text transform="translate(150,192) rotate(300) translate(26,3)" font-family="monospace" font-size="9" font-weight="bold" fill="#c87fb8">{keyword}</text>
  <text transform="translate(150,192) rotate(330) translate(26,3)" font-family="monospace" font-size="9" font-weight="bold" fill="#c87fb8">{keyword}</text>
  <circle cx="150" cy="192" r="8" fill="#c87fb8" opacity="0.5"/>
</svg>
