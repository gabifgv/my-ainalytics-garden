---
const { keyword } = Astro.props;
---
<svg viewBox="0 0 300 400" width="100%" height="auto">
  <path d="M 150 305 Q 150 238 150 212" stroke="var(--stem-color)" stroke-width="3" fill="none"/>
  <text transform="translate(150,200) rotate(-90) translate(58,3)" font-family="monospace" font-size="8" font-weight="bold" fill="#e8b0c0">{keyword}</text>
  <text transform="translate(150,200) rotate(-45) translate(58,3)" font-family="monospace" font-size="8" font-weight="bold" fill="#e8b0c0">{keyword}</text>
  <text transform="translate(150,200) rotate(0) translate(58,3)" font-family="monospace" font-size="8" font-weight="bold" fill="#e8b0c0">{keyword}</text>
  <text transform="translate(150,200) rotate(45) translate(58,3)" font-family="monospace" font-size="8" font-weight="bold" fill="#e8b0c0">{keyword}</text>
  <text transform="translate(150,200) rotate(90) translate(58,3)" font-family="monospace" font-size="8" font-weight="bold" fill="#e8b0c0">{keyword}</text>
  <text transform="translate(150,200) rotate(135) translate(58,3)" font-family="monospace" font-size="8" font-weight="bold" fill="#e8b0c0">{keyword}</text>
  <text transform="translate(150,200) rotate(180) translate(58,3)" font-family="monospace" font-size="8" font-weight="bold" fill="#e8b0c0">{keyword}</text>
  <text transform="translate(150,200) rotate(225) translate(58,3)" font-family="monospace" font-size="8" font-weight="bold" fill="#e8b0c0">{keyword}</text>
  <text transform="translate(150,200) rotate(-60) translate(34,3)" font-family="monospace" font-size="8" font-weight="bold" fill="#d97a8a">{keyword}</text>
  <text transform="translate(150,200) rotate(0) translate(34,3)" font-family="monospace" font-size="8" font-weight="bold" fill="#d97a8a">{keyword}</text>
  <text transform="translate(150,200) rotate(60) translate(34,3)" font-family="monospace" font-size="8" font-weight="bold" fill="#d97a8a">{keyword}</text>
  <text transform="translate(150,200) rotate(120) translate(34,3)" font-family="monospace" font-size="8" font-weight="bold" fill="#d97a8a">{keyword}</text>
  <text transform="translate(150,200) rotate(180) translate(34,3)" font-family="monospace" font-size="8" font-weight="bold" fill="#d97a8a">{keyword}</text>
  <text transform="translate(150,200) rotate(240) translate(34,3)" font-family="monospace" font-size="8" font-weight="bold" fill="#d97a8a">{keyword}</text>
  <text transform="translate(150,200) rotate(-45) translate(16,3)" font-family="monospace" font-size="9" font-weight="bold" fill="#c05070">{keyword}</text>
  <text transform="translate(150,200) rotate(45) translate(16,3)" font-family="monospace" font-size="9" font-weight="bold" fill="#c05070">{keyword}</text>
  <text transform="translate(150,200) rotate(135) translate(16,3)" font-family="monospace" font-size="9" font-weight="bold" fill="#c05070">{keyword}</text>
  <text transform="translate(150,200) rotate(225) translate(16,3)" font-family="monospace" font-size="9" font-weight="bold" fill="#c05070">{keyword}</text>
  <circle cx="150" cy="200" r="7" fill="#c05070" opacity="0.5"/>
</svg>
